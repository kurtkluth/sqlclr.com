---
const links = [
  { href: '/#story', label: 'The Story' },
  { href: '/#practice', label: 'Practice' },
  { href: '/#work', label: 'Work' },
  { href: '/#contact', label: 'Contact' },
];
---

<header class="nav-wrap">
  <nav class="container nav" aria-label="Primary">
    <a href="/" class="brand" aria-label="sqlclr.com home">
      <span class="brand-mark" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 32 32" fill="none">
          <path d="M11.5 7.5v17" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
          <path d="M21.5 7.5 12.5 16l9 8.5" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <span class="brand-text">sqlclr<span class="brand-tld">.com</span></span>
    </a>

    <div class="nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>

    <div class="nav-actions">
      <button type="button" class="theme-toggle" aria-label="Toggle color theme" title="Toggle light / dark">
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
        </svg>
      </button>

      <a href="https://github.com/kurtkluth" target="_blank" rel="noopener" class="btn btn-ghost nav-gh">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
        </svg>
        GitHub
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.querySelector('.theme-toggle');
  btn?.addEventListener('click', () => {
    const next =
      document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', next);
    try {
      localStorage.setItem('theme', next);
    } catch (e) {}
    const meta = document.querySelector('meta[name="theme-color"]');
    if (meta) meta.setAttribute('content', next === 'light' ? '#f6f8fb' : '#07090d');
  });
</script>

<style>
  .nav-wrap {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px) saturate(1.4);
    -webkit-backdrop-filter: blur(14px) saturate(1.4);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border-bottom: 1px solid var(--line);
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 66px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.02rem;
    letter-spacing: -0.02em;
  }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    color: var(--accent-bright);
    background: linear-gradient(160deg, rgba(31, 111, 235, 0.28), rgba(31, 111, 235, 0.06));
    border: 1px solid rgba(88, 166, 255, 0.3);
  }
  .brand-tld { color: var(--text-faint); }
  .nav-links {
    display: flex;
    gap: 2rem;
    font-size: 0.92rem;
    font-weight: 480;
    color: var(--text-dim);
  }
  .nav-links a { transition: color 0.15s ease; }
  .nav-links a:hover { color: var(--text); }
  .nav-gh { padding: 0.5rem 1.1rem; font-size: 0.88rem; }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .theme-toggle {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 1px solid var(--line-strong);
    background: rgba(148, 163, 184, 0.04);
    color: var(--text-dim);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
  }
  .theme-toggle:hover {
    color: var(--text);
    border-color: rgba(148, 163, 184, 0.45);
    background: rgba(148, 163, 184, 0.09);
    transform: translateY(-1px);
  }
  .theme-toggle svg { display: block; }
  /* show the icon for the theme you'd switch TO: sun while dark, moon while light */
  .theme-toggle .icon-sun { display: block; }
  .theme-toggle .icon-moon { display: none; }
  :global(:root[data-theme='light']) .theme-toggle .icon-sun { display: none; }
  :global(:root[data-theme='light']) .theme-toggle .icon-moon { display: block; }

  @media (max-width: 720px) {
    .nav-links { display: none; }
  }
</style>
